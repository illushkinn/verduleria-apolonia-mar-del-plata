---
import Layout from "../layouts/Layout.astro";
import FeaturedProductCard from "../components/product/FeaturedProductCard.jsx";

const destacados = [
  {
    id: 1,
    nombre: "Frutilla de Coronda",
    precio: "$4.500",
    unidad: "kg",
    imagen: null,
    badge: "Temporada",
    badgeIcon: "sparkle",
    estacion: true,
  },
  {
    id: 2,
    nombre: "Mango Petacón",
    precio: "$6.800",
    unidad: "kg",
    imagen: null,
    badge: "Tropical",
    badgeIcon: "star",
    estacion: true,
  },
  {
    id: 3,
    nombre: "Rúcula Fresca",
    precio: "$2.200",
    unidad: "atado",
    imagen: null,
    badge: "Verduras Finas",
    badgeIcon: "leaf",
    estacion: true,
  },
  {
    id: 4,
    nombre: "Tomate Perita",
    precio: "$3.200",
    unidad: "kg",
    imagen: null,
    badge: "De estación",
    badgeIcon: "leaf",
    estacion: true,
  },
];
---

<Layout title="Apolonia — Frutería y Verdulería de Estación">
  <!-- Hero Section -->
  <section class="relative min-h-[80vh] flex items-center bg-gradient-to-br from-brand-red-dark via-brand-red to-brand-red-light overflow-hidden">
    <!-- Background decoration -->
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-20 left-10 w-72 h-72 rounded-full bg-brand-gold blur-3xl"></div>
      <div class="absolute bottom-20 right-10 w-96 h-96 rounded-full bg-brand-terracotta blur-3xl"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <div class="max-w-2xl">
        <p class="font-hand text-brand-gold-light text-xl mb-4 animate-fade-in-up">
          Frutería &amp; Verdulería
        </p>
        <h1 class="font-serif text-5xl sm:text-6xl lg:text-7xl font-bold text-white leading-[1.1] mb-6 animate-fade-in-up">
          Lo mejor de<br />
          <span class="text-brand-gold">cada estación</span>,<br />
          en tu mesa.
        </h1>
        <p class="text-white/80 text-lg sm:text-xl leading-relaxed mb-8 max-w-xl animate-fade-in-up" style="animation-delay: 0.2s;">
          Frutas, verduras y verduras finas seleccionadas para vos. 
          Directo del productor a tu casa, sin cargo.
        </p>
        <div class="flex flex-wrap gap-4 animate-fade-in-up" style="animation-delay: 0.3s;">
          <a
            href="/catalogo"
            class="inline-flex items-center gap-2 px-8 py-4 bg-brand-terracotta text-white font-medium rounded-[--radius-button] hover:bg-brand-terracotta-light transition-all text-lg shadow-lg shadow-brand-terracotta/30"
          >
            Ver Catálogo
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
          <a
            href="/estacion"
            class="inline-flex items-center gap-2 px-8 py-4 bg-white/10 backdrop-blur-sm text-white font-medium rounded-[--radius-button] hover:bg-white/20 transition-all text-lg border border-white/20"
          >
            ¿Qué está de estación?
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Seasonal Section -->
  <section class="py-20 bg-brand-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between mb-12">
        <div>
          <p class="font-hand text-brand-terracotta text-lg mb-2 flex items-center gap-2">
            <svg width="18" height="18" viewBox="0 0 256 256" fill="currentColor"><path d="M184,128a56,56,0,0,0-55.37-48H128A56,56,0,0,0,72,128v32a8,8,0,0,0,8,8h96a8,8,0,0,0,8-8Zm-16,24H88V128a40,40,0,0,1,80,0Z"/><path d="M224,120a8,8,0,0,0-8,8v32a88,88,0,0,1-176,0V128a8,8,0,0,0-16,0v32a104,104,0,0,0,208,0V128A8,8,0,0,0,224,120Z"/><path d="M164.49,57.51a8,8,0,0,1,0-11.32l16-16a8,8,0,0,1,11.32,11.32l-16,16A8,8,0,0,1,164.49,57.51Z"/><path d="M80,57.51,64,41.49a8,8,0,0,1,11.32-11.32l16,16a8,8,0,0,1-11.32,11.32Z"/><circle cx="128" cy="164" r="8"/><circle cx="128" cy="196" r="8"/><circle cx="108" cy="180" r="8"/><circle cx="148" cy="180" r="8"/></svg>
            Esta semana
          </p>
          <h2 class="font-serif text-3xl sm:text-4xl font-bold text-brand-red-dark">
            Destacados de Estación
          </h2>
        </div>
        <a href="/catalogo" class="mt-4 sm:mt-0 text-sm font-medium text-brand-red hover:text-brand-red-light transition-colors">
          Ver todos los productos →
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {destacados.map((producto) => (
          <FeaturedProductCard producto={producto} client:load />
        ))}
      </div>
    </div>
  </section>

  <!-- How it Works -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="font-hand text-brand-terracotta text-lg mb-2">Así de simple</p>
        <h2 class="font-serif text-3xl sm:text-4xl font-bold text-brand-red-dark">
          ¿Cómo funciona?
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-brand-red/10 flex items-center justify-center">
            <span class="font-serif text-2xl font-bold text-brand-red">1</span>
          </div>
          <h3 class="font-serif text-xl font-semibold text-brand-charcoal mb-2">Elegí</h3>
          <p class="text-sm text-brand-charcoal-soft leading-relaxed">
            Navegá nuestro catálogo. Filtrá por estación, categoría o buscá lo que se te antoje.
          </p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-brand-terracotta/10 flex items-center justify-center">
            <span class="font-serif text-2xl font-bold text-brand-terracotta">2</span>
          </div>
          <h3 class="font-serif text-xl font-semibold text-brand-charcoal mb-2">Pedí</h3>
          <p class="text-sm text-brand-charcoal-soft leading-relaxed">
            Agregá al carrito y enviá tu pedido por WhatsApp. En un toque lo tenemos.
          </p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-brand-gold/10 flex items-center justify-center">
            <span class="font-serif text-2xl font-bold text-brand-gold">3</span>
          </div>
          <h3 class="font-serif text-xl font-semibold text-brand-charcoal mb-2">Recibí</h3>
          <p class="text-sm text-brand-charcoal-soft leading-relaxed">
            Te lo llevamos a casa sin cargo. Nuestro cadete te avisa cuando llega.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Seasonal Note -->
  <section class="py-20 bg-brand-red-dark">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="font-hand text-brand-gold-light text-xl mb-4 flex items-center justify-center gap-2">
        <svg width="20" height="20" viewBox="0 0 256 256" fill="currentColor">
          <path d="M208,32H184V24a8,8,0,0,0-16,0v8H48A16,16,0,0,0,32,48V192a16,16,0,0,0,16,16H72v24a8,8,0,0,0,16,0V208H168v24a8,8,0,0,0,16,0V208h24a16,16,0,0,0,16-16V48A16,16,0,0,0,208,32ZM48,192V48H184V192Z"/>
        </svg>
        Lo que está en su punto
      </p>
      <h2 class="font-serif text-3xl sm:text-4xl font-bold text-white mb-6">
        Esta semana tenemos frutilla, mango, rúcula y tomate perita
      </h2>
      <p class="text-white/70 text-lg leading-relaxed mb-8 max-w-2xl mx-auto">
        La naturaleza no se apura, y nosotros tampoco. Todo llega cuando tiene que llegar, 
        y te avisamos para que no te lo pierdas.
      </p>
      <a
        href="/estacion"
        class="inline-flex items-center gap-2 px-8 py-4 bg-brand-terracotta text-white font-medium rounded-[--radius-button] hover:bg-brand-terracotta-light transition-all text-lg"
      >
        Ver frutas y verduras de estación
      </a>
    </div>
  </section>

  <!-- CTA WhatsApp -->
  <section class="py-16 bg-brand-cream">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="font-hand text-brand-terracotta text-lg mb-2 flex items-center justify-center gap-2">
        <svg width="18" height="18" viewBox="0 0 256 256" fill="currentColor">
          <path d="M216,80H184V48a16,16,0,0,0-16-16H40A16,16,0,0,0,24,48V176a8,8,0,0,0,13,6.22L72,154V192a16,16,0,0,0,16,16h93.59L219,230.22a8,8,0,0,0,5,1.78,8,8,0,0,0,8-8V96A16,16,0,0,0,216,80ZM66.06,136,40,158.46V48H168v88ZM208,208.46,182.06,192H88V160h80a16,16,0,0,0,16-16V96h24Z"/>
        </svg>
        ¿Preferís hablar directo?
      </p>
      <h2 class="font-serif text-2xl sm:text-3xl font-bold text-brand-red-dark mb-4">
        Mandanos un WhatsApp y te asesoramos
      </h2>
      <p class="text-brand-charcoal-soft mb-8">
        Respondemos al toque. Decinos qué querés y te preparamos el pedido.
      </p>
      <a
        href="https://wa.me/5492235833114"
        target="_blank"
        class="inline-flex items-center gap-3 px-8 py-4 bg-[#25D366] text-white font-medium rounded-[--radius-button] hover:bg-[#22c35e] transition-all text-lg shadow-lg shadow-[#25D366]/30"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Pedir por WhatsApp
      </a>
    </div>
  </section>
</Layout>
