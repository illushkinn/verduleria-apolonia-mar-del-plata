---
import Layout from "../layouts/Layout.astro";

const mesActual = new Date().toLocaleString("es-AR", { month: "long" });
const mesCapitalized = mesActual.charAt(0).toUpperCase() + mesActual.slice(1);

const frutasEstacion = [
  { nombre: "Frutilla", variedad: "Coronda", precio: "$4.500", unidad: "kg", stock: 12, destacado: true },
  { nombre: "Naranja", variedad: "Ombligo", precio: "$2.800", unidad: "kg", stock: 25 },
  { nombre: "Mango", variedad: "Petacón", precio: "$6.800", unidad: "kg", stock: 8, destacado: true },
  { nombre: "Palta", variedad: "Hass", precio: "$5.200", unidad: "unidad", stock: 15 },
  { nombre: "Limón", variedad: "Meyer", precio: "$2.500", unidad: "kg", stock: 30 },
  { nombre: "Banana", variedad: "Ecuador", precio: "$2.200", unidad: "kg", stock: 20 },
];

const verdurasEstacion = [
  { nombre: "Tomate", variedad: "Perita", precio: "$3.200", unidad: "kg", stock: 18, destacado: true },
  { nombre: "Rúcula", variedad: "Fresca", precio: "$2.200", unidad: "atado", stock: 10, destacado: true },
  { nombre: "Radicheta", variedad: "Orgánica", precio: "$2.500", unidad: "atado", stock: 7 },
  { nombre: "Kale", variedad: "Crespo", precio: "$2.800", unidad: "atado", stock: 5 },
  { nombre: "Zapallo", variedad: "Anco", precio: "$2.000", unidad: "kg", stock: 15 },
  { nombre: "Berenjena", variedad: "Negra", precio: "$3.000", unidad: "kg", stock: 12 },
];
---

<Layout title="Frutas y Verduras de Estación">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-brand-red-dark to-brand-red py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="font-hand text-brand-gold-light text-lg mb-2 animate-fade-in-up flex items-center gap-2">
        <svg width="18" height="18" viewBox="0 0 256 256" fill="currentColor">
          <path d="M128,24A104,104,0,1,0,232,128,104.11,104.11,0,0,0,128,24Zm0,192a88,88,0,1,1,88-88A88.1,88.1,0,0,1,128,216ZM80,112a8,8,0,0,1,8-8h80a8,8,0,0,1,0,16H88A8,8,0,0,1,80,112Zm8,32h80a8,8,0,0,1,0,16H88a8,8,0,0,1,0-16Z"/>
        </svg>
        Estación
      </p>
      <h1 class="font-serif text-4xl sm:text-5xl font-bold text-white mb-4 animate-fade-in-up" style="animation-delay: 0.1s;">
        {mesCapitalized} en tu mesa
      </h1>
      <p class="text-white/85 text-lg max-w-xl animate-fade-in-up" style="animation-delay: 0.2s;">
        Esto es lo que está en su punto este mes. Fresco, directo del productor, esperando por vos.
      </p>
    </div>
  </section>

  <!-- Nota del Verdulero -->
  <section class="py-8 bg-brand-cream-dark border-b border-brand-cream-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-start gap-4">
        <svg width="24" height="24" viewBox="0 0 256 256" fill="currentColor" class="flex-shrink-0 text-brand-charcoal-soft/50">
          <path d="M227.31,73.37,182.63,28.68a16,16,0,0,0-22.63,0L36.69,152A15.86,15.86,0,0,0,32,163.31V208a16,16,0,0,0,16,16H92.69a15.86,15.86,0,0,0,11.31-4.69L227.31,96a16,16,0,0,0,0-22.63ZM92.69,208H48V163.31l88-88L180.69,120ZM192,108.68,147.31,64l24-24L216,84.68Z"/>
        </svg>
        <div>
          <p class="font-hand text-brand-fresh text-xl">
            "La frutilla está en su punto justo. Pedila hoy porque en dos días no queda una."
          </p>
          <p class="text-xs text-brand-charcoal-soft mt-1">— El verdulero</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Frutas de Estación -->
  <section class="py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-serif text-2xl sm:text-3xl font-bold text-brand-red-dark mb-2 flex items-center gap-2">
        <svg width="24" height="24" viewBox="0 0 256 256" fill="currentColor" class="text-brand-red">
          <path d="M184,128a56,56,0,0,0-55.37-48H128A56,56,0,0,0,72,128v32a8,8,0,0,0,8,8h96a8,8,0,0,0,8-8Zm-16,24H88V128a40,40,0,0,1,80,0Z"/>
          <path d="M224,120a8,8,0,0,0-8,8v32a88,88,0,0,1-176,0V128a8,8,0,0,0-16,0v32a104,104,0,0,0,208,0V128A8,8,0,0,0,224,120Z"/>
        </svg>
        Frutas de estación
      </h2>
      <p class="text-sm text-brand-charcoal mb-8">Las que están en su punto justo para comer ahora.</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {frutasEstacion.map((fruta) => (
          <article class="flex items-center gap-4 bg-white p-4 rounded-[--radius-brand] shadow-sm hover:shadow-md transition-all">
            <div class="w-16 h-16 rounded-lg bg-gradient-to-br from-brand-cream-dark to-brand-cream flex items-center justify-center flex-shrink-0">
              <svg width="28" height="28" viewBox="0 0 256 256" fill="currentColor" class="text-brand-charcoal-soft/40">
                <path d="M216,72H176a48,48,0,0,0-96,0H40a8,8,0,0,0-8,8V208a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V80A8,8,0,0,0,216,72ZM128,40a32,32,0,0,1,32,32H96A32,32,0,0,1,128,40Zm80,168H48V88H80v8a8,8,0,0,0,16,0V88h64v8a8,8,0,0,0,16,0V88h32Z"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2">
                <h3 class="font-serif font-semibold text-brand-charcoal truncate">{fruta.nombre}</h3>
                {fruta.destacado && (
                  <span class="px-2 py-0.5 bg-brand-gold/20 text-brand-gold text-[10px] font-medium rounded-full flex items-center gap-1">
                    <svg width="10" height="10" viewBox="0 0 256 256" fill="currentColor">
                      <path d="M234.5,114.38l-45.1,39.36,13.51,58.6a16,16,0,0,1-23.84,17.34l-51.11-31-51,31a16,16,0,0,1-23.84-17.34L66.61,153.74,21.5,114.38a16,16,0,0,1,9.11-28.06l59.46-5.15,23.21-55.36a16,16,0,0,1,29.44,0l23.21,55.36,59.46,5.15a16,16,0,0,1,9.11,28.06Z"/>
                    </svg>
                    Destacado
                  </span>
                )}
              </div>
              <p class="text-xs text-brand-charcoal-soft">{fruta.variedad}</p>
              <div class="flex items-center justify-between mt-2">
                <span class="font-bold text-brand-charcoal">
                  {fruta.precio}
                  <span class="text-xs font-normal text-brand-charcoal-soft">/{fruta.unidad}</span>
                </span>
                <span class="text-xs flex items-center gap-1 text-brand-fresh">
                  <span class="w-1.5 h-1.5 rounded-full bg-brand-fresh"></span>
                  {fruta.stock} kg
                </span>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Verduras de Estación -->
  <section class="py-12 bg-brand-cream-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-serif text-2xl sm:text-3xl font-bold text-brand-red-dark mb-2 flex items-center gap-2">
        <svg width="24" height="24" viewBox="0 0 256 256" fill="currentColor" class="text-brand-fresh">
          <path d="M213.66,42.34a8,8,0,0,0-7.07-2.1C132.57,54.18,92.6,83.13,74.7,130.39c-5.29,14-7.87,28.48-8.86,42.27C52.13,153.75,48,131.14,48,112c0-64,80-80,80-80a8,8,0,0,0,0-16c0,0-96,16-96,96,0,51.79,26.62,79.74,47.34,92.69L56.73,207.6a8,8,0,0,0,11.54,11.06l23.34-24.34C103.21,201.1,113.21,208,128,208a8,8,0,0,0,0-16c-33.85,0-48-28.08-48-48,0-40,40-64,80-72-30.5,58.65-15.54,101.85-2.2,118.17a8,8,0,0,0,13.59-5.74c1.32-23.24,10.91-51.53,25.35-80.35C213.68,87.32,222,55.48,218.49,44.8Z"/>
        </svg>
        Verduras de estación
      </h2>
      <p class="text-sm text-brand-charcoal-soft mb-8">Verduras finas y clásicas en su mejor momento.</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {verdurasEstacion.map((verdura) => (
          <article class="flex items-center gap-4 bg-white p-4 rounded-[--radius-brand] shadow-sm hover:shadow-md transition-all">
            <div class="w-16 h-16 rounded-lg bg-gradient-to-br from-brand-cream-dark to-brand-cream flex items-center justify-center flex-shrink-0">
              <svg width="28" height="28" viewBox="0 0 256 256" fill="currentColor" class="text-brand-charcoal-soft/40">
                <path d="M216,72H176a48,48,0,0,0-96,0H40a8,8,0,0,0-8,8V208a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V80A8,8,0,0,0,216,72ZM128,40a32,32,0,0,1,32,32H96A32,32,0,0,1,128,40Zm80,168H48V88H80v8a8,8,0,0,0,16,0V88h64v8a8,8,0,0,0,16,0V88h32Z"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2">
                <h3 class="font-serif font-semibold text-brand-charcoal truncate">{verdura.nombre}</h3>
                {verdura.destacado && (
                  <span class="px-2 py-0.5 bg-brand-gold/20 text-brand-gold text-[10px] font-medium rounded-full flex items-center gap-1">
                    <svg width="10" height="10" viewBox="0 0 256 256" fill="currentColor">
                      <path d="M234.5,114.38l-45.1,39.36,13.51,58.6a16,16,0,0,1-23.84,17.34l-51.11-31-51,31a16,16,0,0,1-23.84-17.34L66.61,153.74,21.5,114.38a16,16,0,0,1,9.11-28.06l59.46-5.15,23.21-55.36a16,16,0,0,1,29.44,0l23.21,55.36,59.46,5.15a16,16,0,0,1,9.11,28.06Z"/>
                    </svg>
                    Destacado
                  </span>
                )}
              </div>
              <p class="text-xs text-brand-charcoal-soft">{verdura.variedad}</p>
              <div class="flex items-center justify-between mt-2">
                <span class="font-bold text-brand-charcoal">
                  {verdura.precio}
                  <span class="text-xs font-normal text-brand-charcoal-soft">/{verdura.unidad}</span>
                </span>
                <span class="text-xs flex items-center gap-1 text-brand-fresh">
                  <span class="w-1.5 h-1.5 rounded-full bg-brand-fresh"></span>
                  {verdura.stock} kg
                </span>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-serif text-2xl sm:text-3xl font-bold text-brand-red-dark mb-4">
        ¿Querés armar tu pedido?
      </h2>
      <p class="text-brand-charcoal mb-8">
        Agregá lo que quieras al carrito y te lo llevamos a casa sin cargo.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/catalogo" class="px-8 py-4 bg-brand-red text-white font-medium rounded-[--radius-button] hover:bg-brand-red-light transition-all">
          Ver catálogo completo
        </a>
        <a href="https://wa.me/5492235833114" target="_blank" class="px-8 py-4 bg-[#25D366] text-white font-medium rounded-[--radius-button] hover:bg-[#22c35e] transition-all">
          Pedir por WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- Calendario estacional simple -->
  <section class="py-12 bg-brand-red-dark text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-serif text-2xl sm:text-3xl font-bold mb-8 text-center">
        <svg width="24" height="24" viewBox="0 0 256 256" fill="currentColor" class="inline-block mb-1">
          <path d="M208,32H184V24a8,8,0,0,0-16,0v8H88V24a8,8,0,0,0-16,0v8H48A16,16,0,0,0,32,48V208a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V48A16,16,0,0,0,208,32ZM48,48H72v8a8,8,0,0,0,16,0V48h80v8a8,8,0,0,0,16,0V48h24v32H48ZM208,208H48V96H208V208Z"/>
        </svg>
        Calendario de Estación
      </h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 text-center">
        <div class="p-4 bg-white/10 rounded-[--radius-brand]">
          <svg width="28" height="28" viewBox="0 0 256 256" fill="currentColor" class="mx-auto text-brand-gold-light">
            <path d="M248,72a8,8,0,0,0-8-8H192V56a8,8,0,0,0-16,0v8H80V56a8,8,0,0,0-16,0v8H16a8,8,0,0,0,0,16H24v96H16a8,8,0,0,0,0,16H240a8,8,0,0,0,0-16h-8V88h8A8,8,0,0,0,248,72ZM208,88v72H48V88Z"/>
          </svg>
          <p class="font-medium">Verano</p>
          <p class="text-xs text-white/85">Fruta: durazno, sandía, pelón</p>
        </div>
        <div class="p-4 bg-white/10 rounded-[--radius-brand]">
          <svg width="28" height="28" viewBox="0 0 256 256" fill="currentColor" class="mx-auto text-brand-gold-light">
            <path d="M213.66,42.34a8,8,0,0,0-7.07-2.1C132.57,54.18,92.6,83.13,74.7,130.39c-5.29,14-7.87,28.48-8.86,42.27C52.13,153.75,48,131.14,48,112c0-64,80-80,80-80a8,8,0,0,0,0-16c0,0-96,16-96,96,0,51.79,26.62,79.74,47.34,92.69L56.73,207.6a8,8,0,0,0,11.54,11.06l23.34-24.34C103.21,201.1,113.21,208,128,208a8,8,0,0,0,0-16c-33.85,0-48-28.08-48-48,0-40,40-64,80-72-30.5,58.65-15.54,101.85-2.2,118.17a8,8,0,0,0,13.59-5.74c1.32-23.24,10.91-51.53,25.35-80.35C213.68,87.32,222,55.48,218.49,44.8Z"/>
          </svg>
          <p class="font-medium">Otoño</p>
          <p class="text-xs text-white/85">Fruta: pera, manzana, uva</p>
        </div>
        <div class="p-4 bg-white/10 rounded-[--radius-brand]">
          <svg width="28" height="28" viewBox="0 0 256 256" fill="currentColor" class="mx-auto text-brand-gold-light">
            <path d="M216,128a8,8,0,0,1-8,8H136v72a8,8,0,0,1-16,0V136H48a8,8,0,0,1,0-16h72V48a8,8,0,0,1,16,0v72h72A8,8,0,0,1,216,128Z"/>
          </svg>
          <p class="font-medium">Invierno</p>
          <p class="text-xs text-white/85">Fruta: kiwi, mandarina, pomelo</p>
        </div>
        <div class="p-4 bg-white/10 rounded-[--radius-brand]">
          <svg width="28" height="28" viewBox="0 0 256 256" fill="currentColor" class="mx-auto text-brand-gold-light">
            <path d="M184,128a56,56,0,0,0-55.37-48H128A56,56,0,0,0,72,128v32a8,8,0,0,0,8,8h96a8,8,0,0,0,8-8Zm-16,24H88V128a40,40,0,0,1,80,0Z"/>
            <path d="M224,120a8,8,0,0,0-8,8v32a88,88,0,0,1-176,0V128a8,8,0,0,0-16,0v32a104,104,0,0,0,208,0V128A8,8,0,0,0,224,120Z"/>
          </svg>
          <p class="font-medium">Primavera</p>
          <p class="text-xs text-white/85">Fruta: frutilla, cereza, mango</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
