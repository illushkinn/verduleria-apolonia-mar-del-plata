# ─── Apolonia — pnpm Security Config ────────────
# ignore-scripts=true deshabilita TODOS los scripts de instalación
# Solo los paquetes listados en onlyBuiltDependencies pueden ejecutarlos
ignore-scripts=true
onlyBuiltDependencies[]=esbuild
onlyBuiltDependencies[]=sharp

# Lockfile en formato pnpm
lockfile=true
frozen-lockfile=false

# Auditoría de seguridad
audit=true
